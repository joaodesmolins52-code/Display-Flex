#Minha-Blog 
{
    Background-color: #ccb78f;
    width: 80%;
    margin-left: 20%;
    height: 20vh;    
}

#Minha-Blog div
{
    display:flex;
}

#Minha-Blog a 
{
    color: rgba(0, 0, 0, 0.5);
    text-transform: uppercase;
    font-size: 13px;
    letter-spacing: 1px;
    margin-top: 16px;
    margin-left: 30%;
}

#Minhha-Blog p 
{
    text-transform: uppercase;
    font-size: 13px;
    letter-spacing: 1px;
    border-bottom: 2px solid rgba(0, 0, 0, 0.1);
    color: black;
    font-family: 'Montserrat';
    font-style: normal;
    font-weight: 300;
}

#Minha-Blog-text
{
    margin-left: 30%;
}
